    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy --schema=prisma/schema.postgres.prisma",
    "db:seed": "prisma db seed",
    "db:seed:prod": "prisma db seed --schema=prisma/schema.postgres.prisma",
    "db:studio": "prisma studio",
    "vercel-build": "npx prisma generate --schema=prisma/schema.postgres.prisma && next build"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.21.0",
